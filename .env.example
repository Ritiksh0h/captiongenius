# Groq — free at console.groq.com — handles both vision AND captions
GROQ_API_KEY=

# NextAuth
NEXTAUTH_URL=
NEXTAUTH_SECRET=       # openssl rand -base64 32

# Google OAuth — console.cloud.google.com → APIs → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database — Neon serverless Postgres (neon.tech — free tier, no card)
DATABASE_URL=postgresql://...

# Cloudflare R2 image storage (replaces local public/uploads/)
# Cloudflare dashboard → R2 → Create bucket → API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=captiongenius-uploads
R2_PUBLIC_URL=    # Enable public access in R2 bucket settings

# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PLUS_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Cron secret — protects /api/cron/cleanup and /api/cron/health
CRON_SECRET=      # openssl rand -base64 32

# Alert system — resend.com free tier (3,000 emails/month, no card)
RESEND_API_KEY=
ADMIN_ALERT_EMAIL=   # your email — receives cost/quota alerts

# Usage thresholds — warning fires at 85%, auto-pause at 100%
ALERT_THRESHOLD_USERS=8000
ALERT_THRESHOLD_STORAGE_MB=8000
ALERT_THRESHOLD_GROQ_DAILY=12000
ALERT_THRESHOLD_NEON_ROWS=800000

# Kill switch secret — verifies email approve/deny links
KILL_SWITCH_SECRET=   # openssl rand -base64 32
