NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs — Stripe dashboard → Products → (each plan's price ID)
STRIPE_PLUS_PRICE_ID=
STRIPE_PRO_PRICE_ID=
